{
  "name": "@robertvii/ouraclaw-cli",
  "version": "0.2.0",
  "description": "Standalone CLI for Oura automation with an optional OpenClaw skill",
  "main": "dist/index.js",
  "bin": {
    "ouraclaw-cli": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "dev:watch": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "quality": "./code-quality.sh",
    "precommit": "./code-quality.sh"
  },
  "keywords": [
    "oura",
    "cli",
    "health",
    "sleep",
    "openclaw"
  ],
  "author": "Robert",
  "license": "MIT",
  "files": [
    "dist/",
    "skills/",
    "docs/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robert7/ouraclaw-cli.git"
  },
  "bugs": {
    "url": "https://github.com/robert7/ouraclaw-cli/issues"
  },
  "homepage": "https://github.com/robert7/ouraclaw-cli#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.57.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
